/* 全局样式 - PetAvatar */

/* CSS变量定义 */
page {
  --primary-color: #FF6B6B;
  --primary-light: #FF8E8E;
  --primary-dark: #E55A5A;
  --secondary-color: #FFD93D;
  --success-color: #6BCB77;
  --warning-color: #FFA500;
  --danger-color: #FF4757;
  --text-primary: #2D3436;
  --text-secondary: #636E72;
  --text-light: #B2BEC3;
  --bg-primary: #FFF5F5;
  --bg-white: #FFFFFF;
  --bg-gray: #F8F9FA;
  --border-color: #E8E8E8;
  --shadow-light: 0 2px 12px rgba(255, 107, 107, 0.08);
  --shadow-medium: 0 4px 20px rgba(255, 107, 107, 0.12);
  --shadow-heavy: 0 8px 30px rgba(0, 0, 0, 0.1);
  --radius-small: 8px;
  --radius-medium: 16px;
  --radius-large: 24px;
  --radius-round: 50%;
  --font-xs: 22rpx;
  --font-sm: 26rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-xxl: 44rpx;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: var(--font-md);
  color: var(--text-primary);
  background-color: var(--bg-primary);
  line-height: 1.6;
}

/* 通用布局 */
.container {
  padding: 24rpx;
  box-sizing: border-box;
}

.page-container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 卡片样式 */
.card {
  background: var(--bg-white);
  border-radius: var(--radius-medium);
  box-shadow: var(--shadow-light);
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-small);
  padding: 20rpx 48rpx;
  font-size: var(--font-md);
  font-weight: 500;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-outline {
  background: transparent;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
  border-radius: var(--radius-small);
  padding: 18rpx 48rpx;
  font-size: var(--font-md);
  font-weight: 500;
  text-align: center;
}

.btn-outline:active {
  background: rgba(255, 107, 107, 0.05);
}

.btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* 表单样式 */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-bottom: 8rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: var(--bg-gray);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-small);
  padding: 0 24rpx;
  font-size: var(--font-md);
  color: var(--text-primary);
  box-sizing: border-box;
}

.form-input:focus {
  border-color: var(--primary-color);
  background: var(--bg-white);
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: var(--font-xs);
  font-weight: 500;
}

.tag-primary {
  background: rgba(255, 107, 107, 0.1);
  color: var(--primary-color);
}

.tag-success {
  background: rgba(107, 203, 119, 0.1);
  color: var(--success-color);
}

.tag-warning {
  background: rgba(255, 165, 0, 0.1);
  color: var(--warning-color);
}

/* Flex布局 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

/* 文本 */
.text-center {
  text-align: center;
}

.text-primary {
  color: var(--primary-color);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-light {
  color: var(--text-light);
}

.text-bold {
  font-weight: 600;
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 间距 */
.mt-8 { margin-top: 8rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-8 { margin-bottom: 8rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.p-16 { padding: 16rpx; }
.p-24 { padding: 24rpx; }

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border-color);
  margin: 24rpx 0;
}

/* 加载中 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-text {
  color: var(--text-light);
  font-size: var(--font-sm);
  margin-top: 16rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-state text {
  color: var(--text-light);
  font-size: var(--font-md);
}

/* 安全区域 */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
