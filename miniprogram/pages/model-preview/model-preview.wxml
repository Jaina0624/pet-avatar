<!-- 3D形象预览页面 -->
<view class="page-container">
  <!-- 3D视图区域 -->
  <view class="viewer-container">
    <view class="viewer-toolbar">
      <view class="tool-btn" bindtap="resetView">
        <text>🔄</text>
      </view>
      <view class="tool-btn" bindtap="toggleAnimation">
        <text>{{animating ? '⏸' : '▶️'}}</text>
      </view>
      <view class="tool-btn" bindtap="takeSnapshot">
        <text>📸</text>
      </view>
      <view class="tool-btn" bindtap="toggleAR" wx:if="{{arSupported}}">
        <text>👁️</text>
      </view>
    </view>
    
    <!-- 3D Canvas -->
    <canvas 
      type="webgl" 
      id="three-canvas" 
      class="three-canvas"
      bindtouchstart="onTouchStart"
      bindtouchmove="onTouchMove"
      bindtouchend="onTouchEnd"
    ></canvas>

    <!-- 加载状态 -->
    <view class="viewer-loading" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">3D模型加载中...</text>
    </view>

    <!-- 无模型提示 -->
    <view class="viewer-empty" wx:if="{{!loading && !modelUrl}}">
      <text class="empty-icon">🐾</text>
      <text class="empty-title">暂无3D形象</text>
      <text class="empty-desc">请先创建宠物档案，上传照片后系统将自动生成</text>
      <view class="btn-primary" bindtap="goToPetProfile">创建宠物档案</view>
    </view>
  </view>

  <!-- 宠物信息卡片 -->
  <view class="pet-info-card container" wx:if="{{petInfo}}">
    <view class="flex-between">
      <view class="flex-row">
        <image class="pet-avatar" src="{{petInfo.avatar}}" mode="aspectFill" />
        <view>
          <text class="pet-name">{{petInfo.name}}</text>
          <text class="pet-breed">{{petInfo.breed}}</text>
        </view>
      </view>
      <view class="pet-tier tag tag-primary">{{petInfo.sizeTierLabel}}</view>
    </view>
  </view>

  <!-- 装扮商城 -->
  <view class="section container" wx:if="{{modelUrl}}">
    <view class="section-header flex-between">
      <text class="section-title">虚拟装扮</text>
      <text class="section-more">更多 ></text>
    </view>
    <scroll-view class="dress-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="dress-inner flex-row">
        <view 
          class="dress-item {{item.equipped ? 'equipped' : ''}}" 
          wx:for="{{dressItems}}" 
          wx:key="id"
          bindtap="toggleDress"
          data-id="{{item.id}}"
        >
          <image class="dress-image" src="{{item.icon}}" mode="aspectFit" />
          <text class="dress-name">{{item.name}}</text>
          <text class="dress-price" wx:if="{{item.price > 0}}">{{item.price}}积分</text>
          <text class="dress-free" wx:else>免费</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 下载桌宠 -->
  <view class="download-section container" wx:if="{{modelUrl}}">
    <view class="download-card">
      <view class="flex-row">
        <text class="download-icon">💻</text>
        <view class="download-info">
          <text class="download-title">下载电子桌宠</text>
          <text class="download-desc">让宝贝在桌面陪伴你办公</text>
        </view>
      </view>
      <view class="btn-outline" bindtap="downloadDesktopPet">下载桌面版</view>
    </view>
  </view>
</view>
