/* 3D预览页样式 */
.viewer-container {
  position: relative;
  width: 100%;
  height: 750rpx;
  background: linear-gradient(180deg, #F0F0FF 0%, #E8E8FF 50%, #F5F5FF 100%);
  overflow: hidden;
}

.viewer-toolbar {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  z-index: 10;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tool-btn {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  font-size: 28rpx;
}

.tool-btn:active {
  transform: scale(0.9);
}

.three-canvas {
  width: 100%;
  height: 100%;
}

/* 加载 */
.viewer-loading {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.8);
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #E8E8E8;
  border-top-color: #FF6B6B;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 空状态 */
.viewer-empty {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.empty-icon {
  font-size: 100rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #636E72;
}

.empty-desc {
  font-size: 24rpx;
  color: #B2BEC3;
  text-align: center;
  padding: 0 60rpx;
}

/* 宠物信息 */
.pet-info-card {
  margin-top: -30rpx;
  position: relative;
  z-index: 2;
}

.pet-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.pet-name {
  font-size: 28rpx;
  font-weight: 600;
}

.pet-breed {
  font-size: 22rpx;
  color: #B2BEC3;
}

/* 装扮 */
.dress-scroll {
  white-space: nowrap;
}

.dress-inner {
  display: inline-flex;
  gap: 16rpx;
}

.dress-item {
  width: 140rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 16rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  border: 2rpx solid transparent;
  flex-shrink: 0;
}

.dress-item.equipped {
  border-color: #FF6B6B;
  background: rgba(255, 107, 107, 0.05);
}

.dress-image {
  width: 64rpx;
  height: 64rpx;
}

.dress-name {
  font-size: 22rpx;
  color: #636E72;
}

.dress-price {
  font-size: 20rpx;
  color: #FF6B6B;
}

.dress-free {
  font-size: 20rpx;
  color: #6BCB77;
}

/* 下载 */
.download-section {
  margin-top: 32rpx;
  margin-bottom: 40rpx;
}

.download-card {
  background: linear-gradient(135deg, #6C5CE7, #A29BFE);
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.download-icon {
  font-size: 52rpx;
  margin-right: 16rpx;
}

.download-info {
  display: flex;
  flex-direction: column;
}

.download-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.download-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

.download-card .btn-outline {
  border-color: #FFFFFF;
  color: #FFFFFF;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
}
