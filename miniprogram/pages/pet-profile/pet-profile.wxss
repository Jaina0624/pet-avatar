/* 宠物档案样式 */
.profile-header {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  padding: 60rpx 32rpx 40rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.profile-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.profile-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
  display: block;
}

/* 步骤指示器 */
.steps {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 40rpx;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.step-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #E8E8E8;
  color: #B2BEC3;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
}

.step.active .step-circle {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  color: #FFFFFF;
}

.step-label {
  font-size: 22rpx;
  color: #B2BEC3;
}

.step.active .step-label {
  color: #FF6B6B;
  font-weight: 600;
}

.step-line {
  width: 80rpx;
  height: 3rpx;
  background: #E8E8E8;
  margin: 0 16rpx;
  margin-bottom: 28rpx;
}

.step-line.active {
  background: #FF6B6B;
}

/* 表单 */
.form-label.required::after {
  content: ' *';
  color: #FF4757;
}

.card-desc {
  font-size: 24rpx;
  color: #B2BEC3;
  display: block;
  margin-top: 8rpx;
}

/* 选项行 */
.option-row {
  display: flex;
  gap: 16rpx;
}

.option-item {
  flex: 1;
  height: 88rpx;
  background: #F8F9FA;
  border: 2rpx solid #E8E8E8;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #636E72;
}

.option-item.selected {
  border-color: #FF6B6B;
  background: rgba(255, 107, 107, 0.05);
  color: #FF6B6B;
  font-weight: 600;
}

.option-emoji {
  font-size: 32rpx;
}

/* Picker */
.picker-input {
  height: 88rpx;
  background: #F8F9FA;
  border: 2rpx solid #E8E8E8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-input .placeholder {
  color: #B2BEC3;
}

.picker-arrow {
  color: #B2BEC3;
  font-size: 20rpx;
}

/* 照片上传 */
.photo-grid {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.photo-item {
  flex: 1;
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.photo-placeholder {
  width: 100%;
  height: 100%;
  background: #F8F9FA;
  border: 2rpx dashed #E8E8E8;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.photo-icon {
  font-size: 48rpx;
}

.photo-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #636E72;
}

.photo-hint {
  font-size: 20rpx;
  color: #B2BEC3;
}

.photo-preview {
  width: 100%;
  height: 100%;
}

.photo-actions {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.5);
  padding: 8rpx 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.photo-tag {
  font-size: 20rpx;
  color: #FFFFFF;
}

.photo-retake {
  font-size: 20rpx;
  color: #FFD93D;
}

/* 测量指南 */
.measure-guide {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 24rpx 0;
  padding: 24rpx;
  background: #FFF8E1;
  border-radius: 12rpx;
}

.guide-image {
  width: 100%;
  height: 300rpx;
}

.guide-link {
  font-size: 24rpx;
  color: #FF6B6B;
  margin-top: 12rpx;
}

/* 体型匹配结果 */
.size-tier-result {
  background: linear-gradient(135deg, rgba(107, 203, 119, 0.1), rgba(107, 203, 119, 0.05));
  border: 2rpx solid #6BCB77;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.tier-label {
  font-size: 24rpx;
  color: #636E72;
}

.tier-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #6BCB77;
}

.tier-desc {
  font-size: 22rpx;
  color: #636E72;
}

/* 按钮组 */
.btn-group {
  display: flex;
  gap: 16rpx;
}
