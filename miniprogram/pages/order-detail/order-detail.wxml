<!-- 订单详情页面 -->
<view class="page-container">
  <view class="order-detail">
    <!-- 状态区 -->
    <view class="status-section">
      <text class="status-icon">{{statusIcon}}</text>
      <text class="status-text">{{statusLabel}}</text>
      <text class="status-hint" wx:if="{{needPay}}">请尽快完成支付，以免订单取消</text>
    </view>

    <!-- 订单信息 -->
    <view class="info-card card">
      <view class="info-row" wx:for="{{infoList}}" wx:key="label">
        <text class="info-label">{{item.label}}</text>
        <text class="info-value">{{item.value}}</text>
      </view>
    </view>

    <!-- 支付按钮 -->
    <view class="btn-primary pay-btn" wx:if="{{needPay}}" bindtap="doPay">立即支付 ¥{{orderInfo.total_price}}</view>

    <!-- 生产进度 -->
    <view class="progress-section card" wx:if="{{!needPay}}">
      <text class="card-title">制作进度</text>
      <view class="progress-steps">
        <view class="progress-item {{item.done ? 'done' : ''}}" wx:for="{{progressSteps}}" wx:key="label">
          <view class="progress-dot"></view>
          <text class="progress-label">{{item.label}}</text>
          <text class="progress-time">{{item.time}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
