/* 订单详情样式 */
.order-detail { padding: 0; }

.status-section {
  background: linear-gradient(135deg, #6C5CE7, #A29BFE);
  padding: 60rpx 32rpx;
  text-align: center;
}

.status-icon { font-size: 80rpx; display: block; }
.status-text { font-size: 36rpx; font-weight: 700; color: #FFFFFF; display: block; margin-top: 12rpx; }
.status-hint { font-size: 24rpx; color: rgba(255,255,255,0.8); display: block; margin-top: 8rpx; }

.info-card { margin: 24rpx; }
.info-row { display: flex; justify-content: space-between; padding: 16rpx 0; border-bottom: 1rpx solid #F5F5F5; }
.info-row:last-child { border-bottom: none; }
.info-label { font-size: 26rpx; color: #636E72; }
.info-value { font-size: 26rpx; font-weight: 500; }

.pay-btn { margin: 24rpx; text-align: center; height: 88rpx; line-height: 88rpx; font-size: 32rpx; }

.progress-section { margin: 24rpx; }
.progress-steps { margin-top: 24rpx; padding-left: 24rpx; }
.progress-item { position: relative; padding: 0 0 32rpx 32rpx; border-left: 4rpx solid #E8E8E8; }
.progress-item.done { border-left-color: #6BCB77; }
.progress-item:last-child { border-left-color: transparent; }
.progress-dot { position: absolute; left: -14rpx; width: 24rpx; height: 24rpx; border-radius: 50%; background: #E8E8E8; }
.progress-item.done .progress-dot { background: #6BCB77; }
.progress-label { font-size: 28rpx; font-weight: 500; }
.progress-time { font-size: 22rpx; color: #B2BEC3; display: block; margin-top: 4rpx; }
