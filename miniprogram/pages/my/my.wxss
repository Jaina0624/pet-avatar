/* 我的页面样式 */
.my-header {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  padding: 80rpx 32rpx 40rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.4);
  margin-right: 20rpx;
}

.user-avatar-placeholder {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 20rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 4rpx;
  display: block;
}

/* 积分卡片 */
.points-card {
  background: rgba(255,255,255,0.15);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 24rpx;
  backdrop-filter: blur(10rpx);
}

.points-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFD93D;
}

.points-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  display: block;
  margin-top: 4rpx;
}

.points-action {
  color: rgba(255,255,255,0.9);
  font-size: 26rpx;
}

.points-action .arrow {
  margin-left: 8rpx;
}

/* 宠物迷你列表 */
.pet-mini-list {
  gap: 16rpx;
  padding: 8rpx 0;
}

.pet-mini-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.pet-mini-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid #FF6B6B;
}

.pet-mini-name {
  font-size: 22rpx;
  color: #636E72;
}

/* 订单标签 */
.order-tabs {
  margin-bottom: 20rpx;
  gap: 0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #636E72;
  border-bottom: 3rpx solid transparent;
}

.tab-item.active {
  color: #FF6B6B;
  border-bottom-color: #FF6B6B;
  font-weight: 600;
}

/* 功能列表 */
.func-list {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
}

.func-item {
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.func-item:last-child {
  border-bottom: none;
}

.func-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.func-name {
  font-size: 28rpx;
}

.func-arrow {
  color: #CCC;
  font-size: 24rpx;
}
