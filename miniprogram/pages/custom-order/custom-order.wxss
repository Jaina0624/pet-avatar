/* 服装定制页样式 */
.custom-header {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  padding: 60rpx 32rpx 40rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.custom-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.custom-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
  display: block;
}

/* 步骤导航 */
.custom-steps {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  margin: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.custom-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  opacity: 0.4;
}

.custom-step.active {
  opacity: 1;
}

.step-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #E8E8E8;
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
}

.custom-step.active .step-num {
  background: #FF6B6B;
  color: #FFFFFF;
}

.step-text {
  font-size: 20rpx;
  color: #636E72;
}

.custom-step.active .step-text {
  color: #FF6B6B;
}

.step-arrow {
  color: #E8E8E8;
  margin: 0 8rpx;
  margin-bottom: 18rpx;
  font-size: 20rpx;
}

/* 宠物选择卡片 */
.pet-select-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid transparent;
  position: relative;
}

.pet-select-card.selected {
  border-color: #FF6B6B;
  background: rgba(255, 107, 107, 0.03);
}

.pet-select-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.pet-select-info {
  flex: 1;
}

.pet-select-name {
  font-size: 28rpx;
  font-weight: 600;
}

.pet-select-breed {
  font-size: 22rpx;
  color: #B2BEC3;
  display: block;
  margin-top: 4rpx;
}

.pet-select-sizes {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
}

.size-item {
  font-size: 20rpx;
  color: #636E72;
  background: #F8F9FA;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.pet-select-check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #FF6B6B;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

/* 款式选择 */
.style-select-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.style-select-card {
  width: calc(50% - 8rpx);
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx solid transparent;
  position: relative;
}

.style-select-card.selected {
  border-color: #FF6B6B;
}

.style-select-image {
  width: 100%;
  height: 260rpx;
}

.style-select-info {
  padding: 16rpx 16rpx 4rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.style-select-name {
  font-size: 26rpx;
  font-weight: 600;
}

.style-select-price {
  font-size: 28rpx;
  color: #FF6B6B;
  font-weight: 600;
}

.style-select-desc {
  font-size: 22rpx;
  color: #B2BEC3;
  padding: 0 16rpx 16rpx;
  display: block;
}

.style-select-check {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #FF6B6B;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

/* 布料预览 */
.fabric-preview {
  background: #F0F0FF;
  border-radius: 16rpx;
  height: 400rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.preview-3d {
  width: 100%;
  height: 100%;
}

.fabric-canvas {
  width: 100%;
  height: 100%;
}

/* 布料分类 */
.cat-scroll {
  white-space: nowrap;
  margin-bottom: 16rpx;
}

.cat-inner {
  display: inline-flex;
  gap: 12rpx;
}

.cat-item {
  padding: 12rpx 24rpx;
  background: #F8F9FA;
  border-radius: 40rpx;
  font-size: 24rpx;
  color: #636E72;
  flex-shrink: 0;
}

.cat-item.active {
  background: #FF6B6B;
  color: #FFFFFF;
}

/* 布料网格 */
.fabric-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.fabric-item {
  width: calc(33.33% - 11rpx);
  background: #FFFFFF;
  border-radius: 12rpx;
  overflow: hidden;
  border: 2rpx solid transparent;
}

.fabric-item.selected {
  border-color: #FF6B6B;
}

.fabric-thumb {
  width: 100%;
  height: 160rpx;
}

.fabric-name {
  font-size: 22rpx;
  color: #636E72;
  padding: 8rpx 12rpx 0;
  display: block;
}

.fabric-price {
  font-size: 20rpx;
  color: #FF6B6B;
  padding: 4rpx 12rpx 12rpx;
  display: block;
}

.fabric-price.free {
  color: #6BCB77;
}

/* 订单摘要 */
.order-summary {
  margin-bottom: 24rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.summary-row:last-child {
  border-bottom: none;
}

.summary-label {
  font-size: 26rpx;
  color: #636E72;
  flex-shrink: 0;
}

.summary-value {
  font-size: 26rpx;
  font-weight: 500;
}

.summary-fabric {
  width: 40rpx;
  height: 40rpx;
  border-radius: 6rpx;
  margin-right: 8rpx;
}

/* 备注 */
.remark-input {
  width: 100%;
  min-height: 120rpx;
  background: #F8F9FA;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 26rpx;
  margin-top: 16rpx;
  box-sizing: border-box;
}

/* 提交区域 */
.submit-section {
  position: sticky;
  bottom: 0;
  background: #FFFFFF;
  border-radius: 20rpx 20rpx 0 0;
  padding: 24rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
}

.total-bar {
  margin-bottom: 20rpx;
}

.total-label {
  font-size: 28rpx;
  color: #636E72;
}

.total-price-row {
  display: flex;
  align-items: baseline;
}

.total-symbol {
  font-size: 28rpx;
  color: #FF6B6B;
  font-weight: 600;
}

.total-price {
  font-size: 52rpx;
  color: #FF6B6B;
  font-weight: 700;
}

.btn-submit {
  width: 100%;
  height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
}

/* 按钮组 */
.btn-group {
  display: flex;
  gap: 16rpx;
}

/* 样衣模拟预览 */
.sample-preview {
  margin-bottom: 24rpx;
}

.preview-body {
  position: relative;
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #FFF5F5;
  margin-top: 16rpx;
}

.preview-pet {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.3;
}

.preview-fabric {
  position: absolute;
  top: 60rpx;
  left: 60rpx;
  width: calc(100% - 120rpx);
  height: 240rpx;
  border-radius: 16rpx;
  opacity: 0.7;
}

.preview-style {
  position: absolute;
  top: 30rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 280rpx;
  height: 300rpx;
}

.preview-info {
  position: absolute;
  bottom: 16rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(255,255,255,0.9);
  border-radius: 12rpx;
  padding: 12rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.preview-style-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF6B6B;
}

.preview-fabric-name {
  font-size: 22rpx;
  color: #636E72;
}
